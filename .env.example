CLERK_SECRET_KEY=
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_JWT_KEY=-----BEGIN PUBLIC KEY-----\nYOUR_CLERK_JWT_PUBLIC_KEY\n-----END PUBLIC KEY-----
CLERK_ADMIN_USER_IDS=user_1234567890
CLERK_ALLOWED_PARTIES=http://localhost:8000,http://localhost:5173,http://127.0.0.1:8000,http://127.0.0.1:5173
CLERK_ALLOWED_ISSUERS=
CLERK_REQUIRE_AZP=true
ANALYTICS_DB_PATH=data/app_analytics.db
ENABLE_DEBUG_LOGS=false
EXPOSE_AUTH_DIAGNOSTICS=false
PDF_PARSE_EXECUTOR=auto
PDF_PARSE_TIMEOUT_SECONDS=120

# Razorpay payments. Use test keys in non-production environments.
# Generate from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Optional: webhook secret configured in the Razorpay dashboard.
RAZORPAY_WEBHOOK_SECRET=
# Required for "Subscribe monthly": create a monthly plan in Razorpay dashboard
# with billing amount Rs 2,360 (Rs 2,000 + 18% GST) and paste plan_id here.
RAZORPAY_PLAN_ID=
# Amount charged per month in paise (Rs 2,360 = 236000). Must match the plan amount above.
RAZORPAY_DEFAULT_AMOUNT_PAISE=236000
# Optional: currency code (defaults to INR).
RAZORPAY_CURRENCY=INR
# Optional: human-readable plan description shown on /billing.
RAZORPAY_PLAN_DESCRIPTION=Echo Analyze — Rs 2,000/month + 18% GST (Rs 2,360 total)
# Optional: subscription billing cycles to charge before stopping (default 12).
RAZORPAY_SUBSCRIPTION_TOTAL_COUNT=12
