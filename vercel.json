{
  "version": 2,
  "builds": [
    {
      "src": "app/Code/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "^/$",
      "headers": {
        "Cache-Control": "no-store, max-age=0"
      },
      "continue": true
    },
    {
      "src": "^/dashboard$",
      "headers": {
        "Cache-Control": "no-store, max-age=0"
      },
      "continue": true
    },
    {
      "src": "^/dashboard/(.*)$",
      "headers": {
        "Cache-Control": "no-store, max-age=0"
      },
      "continue": true
    },
    {
      "src": "^/admin$",
      "headers": {
        "Cache-Control": "no-store, max-age=0"
      },
      "continue": true
    },
    {
      "src": "^/admin/(.*)$",
      "headers": {
        "Cache-Control": "no-store, max-age=0"
      },
      "continue": true
    },
    {
      "src": "/api/(.*)",
      "dest": "app/Code/main.py"
    },
    {
      "src": "/__clerk",
      "dest": "app/Code/main.py"
    },
    {
      "src": "/__clerk/(.*)",
      "dest": "app/Code/main.py"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/static/assets/$1"
    },
    {
      "src": "/Images/(.*)",
      "dest": "/static/Images/$1"
    },
    {
      "src": "/dashboard",
      "dest": "app/Code/main.py"
    },
    {
      "src": "/dashboard/(.*)",
      "dest": "app/Code/main.py"
    },
    {
      "src": "/admin",
      "dest": "app/Code/main.py"
    },
    {
      "src": "/admin/(.*)",
      "dest": "app/Code/main.py"
    },
    {
      "src": "/",
      "dest": "app/Code/main.py"
    },
    {
      "src": "/(.*)",
      "dest": "/static/$1"
    }
  ]
}
