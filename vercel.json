{
  "version": 2,
  "builds": [
    {
      "src": "app/Code/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "app/Code/main.py"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/static/assets/$1"
    },
    {
      "src": "/Images/(.*)",
      "dest": "/static/Images/$1"
    },
    {
      "src": "/vite.svg",
      "dest": "/static/vite.svg"
    },
    {
      "src": "/dashboard",
      "dest": "/static/index.html"
    },
    {
      "src": "/dashboard/(.*)",
      "dest": "/static/index.html"
    },
    {
      "src": "/",
      "dest": "/static/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/static/$1"
    }
  ]
}
